---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact';
---

<Layout title="Contact - Content Hub">
	<div class="contact-page-container">
		<header class="contact-header">
			<h1>Contact</h1>
			<p>Let's start a conversation</p>
		</header>

		<div class="contact-content">
			<div class="contact-info">
				<h2>Connect With Me</h2>
				<div class="info-item">
					<strong>Email</strong>
					<p>hello@contenthub.example</p>
				</div>
				<div class="info-item">
					<strong>Location</strong>
					<p>San Francisco, CA</p>
				</div>
				<div class="info-item">
					<strong>Availability</strong>
					<p>Open for new projects</p>
				</div>
			</div>

			<div class="contact-form-wrapper">
				<Contact client:load />
			</div>
		</div>
	</div>
</Layout>

<style>
	.contact-page-container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 2rem;
	}

	.contact-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.contact-header h1 {
		font-size: 3.5rem;
		margin-bottom: 1rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.contact-header p {
		font-size: 1.25rem;
		color: #6b7280;
	}

	.contact-content {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 4rem;
		align-items: start;
	}

	.contact-info {
		background: white;
		padding: 2rem;
		border-radius: 12px;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
		border: 1px solid #e5e7eb;
	}

	.contact-info h2 {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		color: #1f2937;
	}

	.info-item {
		margin-bottom: 2rem;
	}

	.info-item strong {
		display: block;
		color: #667eea;
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.info-item p {
		color: #4b5563;
		margin: 0;
		font-size: 1.125rem;
	}

	.contact-form-wrapper {
		background: white;
		padding: 2rem;
		border-radius: 12px;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
		border: 1px solid #e5e7eb;
	}

	:global(.contact-form-container) {
		width: 100%;
	}

	:global(.contact-form-container h2) {
		font-size: 2rem;
		margin-bottom: 0.5rem;
		color: #1f2937;
	}

	:global(.contact-description) {
		color: #6b7280;
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	:global(.contact-form) {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	:global(.form-group) {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	:global(.form-group label) {
		font-weight: 500;
		color: #374151;
		font-size: 0.875rem;
	}

	:global(.form-group input),
	:global(.form-group textarea) {
		padding: 0.75rem;
		border: 2px solid #e5e7eb;
		border-radius: 8px;
		font-size: 1rem;
		font-family: inherit;
		transition: border-color 0.2s;
	}

	:global(.form-group input:focus),
	:global(.form-group textarea:focus) {
		outline: none;
		border-color: #667eea;
	}

	:global(.form-group textarea) {
		resize: vertical;
		min-height: 120px;
	}

	:global(.submit-button) {
		padding: 1rem 2rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		border: none;
		border-radius: 8px;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	:global(.submit-button:hover:not(:disabled)) {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
	}

	:global(.submit-button:disabled) {
		opacity: 0.6;
		cursor: not-allowed;
	}

	:global(.success-message) {
		padding: 1rem;
		background: #d1fae5;
		color: #065f46;
		border-radius: 8px;
		text-align: center;
		font-weight: 500;
	}

	:global(.error-message) {
		padding: 1rem;
		background: #fee2e2;
		color: #991b1b;
		border-radius: 8px;
		text-align: center;
		font-weight: 500;
	}

	@media (max-width: 768px) {
		.contact-page-container {
			padding: 1rem;
		}

		.contact-header h1 {
			font-size: 2.5rem;
		}

		.contact-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
