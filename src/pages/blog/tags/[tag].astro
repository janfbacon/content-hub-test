---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/BlogCard.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const allTags = [...new Set(posts.flatMap(post => post.data.tags))];
	
	return allTags.map((tag) => {
		const taggedPosts = posts.filter(post => 
			post.data.tags.includes(tag)
		);
		
		return {
			params: { tag },
			props: { 
				tag,
				posts: taggedPosts.sort((a, b) => 
					b.data.pubDate.getTime() - a.data.pubDate.getTime()
				)
			},
		};
	});
}

interface Props {
	tag: string;
	posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { tag, posts } = Astro.props;
---

<Layout title={`${tag} - Tags - Blog`}>
	<div class="tag-page-container">
		<header class="tag-header">
			<a href="/blog" class="back-link">← Back to Blog</a>
			<h1>Tag: {tag}</h1>
			<p>{posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with "{tag}"</p>
		</header>

		<main class="tag-posts">
			{posts.length > 0 ? (
				<div class="blog-grid">
					{posts.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			) : (
				<p class="no-posts">No posts found for this tag.</p>
			)}
		</main>
	</div>
</Layout>

<style>
	.tag-page-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
	}

	.tag-header {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 2px solid #e5e7eb;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		margin-bottom: 1rem;
		color: #667eea;
		text-decoration: none;
		font-weight: 500;
		transition: transform 0.2s;
	}

	.back-link:hover {
		transform: translateX(-4px);
	}

	.tag-header h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.tag-header p {
		color: #6b7280;
		font-size: 1.1rem;
	}

	.tag-posts {
		min-height: 400px;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
	}

	.no-posts {
		text-align: center;
		color: #9ca3af;
		font-size: 1.125rem;
		padding: 3rem;
	}

	@media (max-width: 768px) {
		.tag-page-container {
			padding: 1rem;
		}

		.tag-header h1 {
			font-size: 2rem;
		}
	}
</style>
