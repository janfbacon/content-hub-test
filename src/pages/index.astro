---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';

// Get latest 3 blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);
---

<Layout title="Content Hub - Hyper-Fast Content & Portfolio Hub">
	<div class="home-container">
		<section class="hero">
			<div class="hero-content">
				<h1 class="hero-title">
					Hyper-Fast Content & Portfolio Hub
				</h1>
				<p class="hero-description">
					Built with Astro's unique Islands Architecture, mixing static content 
					with interactive components for the best performance and user experience.
				</p>
				<div class="hero-cta">
					<a href="/blog" class="cta-button primary">Explore Blog</a>
					<a href="/portfolio" class="cta-button secondary">View Portfolio</a>
				</div>
			</div>
		</section>

		<section class="features">
			<div class="features-grid">
				<div class="feature-card">
					<div class="feature-icon">📝</div>
					<h2>Content Collections</h2>
					<p>Manage your blog posts with Astro's powerful Content Collections API using Markdown and MDX.</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">⚡</div>
					<h2>Islands Architecture</h2>
					<p>Mix static content with interactive React components using client directives for optimal performance.</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🏷️</div>
					<h2>Dynamic Tags</h2>
					<p>Automatically generate tag pages using getStaticPaths() for every unique tag in your blog.</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🖼️</div>
					<h2>Image Optimization</h2>
					<p>Built-in Image component automatically optimizes images with multiple formats and responsive sizes.</p>
				</div>
			</div>
		</section>

		<section class="latest-posts">
			<h2 class="section-title">Latest Blog Posts</h2>
			<div class="posts-grid">
				{latestPosts.map((post) => (
					<BlogCard post={post} />
				))}
			</div>
			<div class="section-cta">
				<a href="/blog" class="cta-link">View All Posts →</a>
			</div>
		</section>

		<section class="cta-section">
			<div class="cta-content">
				<h2>Ready to Get Started?</h2>
				<p>Explore the blog, check out the portfolio, or get in touch to start a conversation.</p>
				<div class="cta-buttons">
					<a href="/contact" class="cta-button primary">Contact Me</a>
					<a href="/portfolio" class="cta-button secondary">View Portfolio</a>
				</div>
			</div>
		</section>
	</div>
</Layout>

<style>
	.home-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.hero {
		text-align: center;
		padding: 6rem 0 4rem;
	}

	.hero-title {
		font-size: 4rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		line-height: 1.2;
	}

	.hero-description {
		font-size: 1.5rem;
		color: #6b7280;
		max-width: 800px;
		margin: 0 auto 3rem;
		line-height: 1.6;
	}

	.hero-cta {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cta-button {
		padding: 1rem 2rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s;
		display: inline-block;
	}

	.cta-button.primary {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
	}

	.cta-button.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(102, 126, 234, 0.4);
	}

	.cta-button.secondary {
		background: white;
		color: #667eea;
		border: 2px solid #667eea;
	}

	.cta-button.secondary:hover {
		background: #667eea;
		color: white;
	}

	.features {
		padding: 4rem 0;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}

	.feature-card {
		background: white;
		padding: 2rem;
		border-radius: 12px;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
		border: 1px solid #e5e7eb;
		text-align: center;
		transition: transform 0.2s;
	}

	.feature-card:hover {
		transform: translateY(-4px);
	}

	.feature-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.feature-card h2 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: #1f2937;
	}

	.feature-card p {
		color: #6b7280;
		line-height: 1.6;
		margin: 0;
	}

	.latest-posts {
		padding: 4rem 0;
	}

	.section-title {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 3rem;
		color: #1f2937;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.section-cta {
		text-align: center;
	}

	.cta-link {
		color: #667eea;
		text-decoration: none;
		font-weight: 600;
		font-size: 1.125rem;
		transition: transform 0.2s;
		display: inline-block;
	}

	.cta-link:hover {
		transform: translateX(4px);
	}

	.cta-section {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border-radius: 16px;
		padding: 4rem 2rem;
		margin: 4rem 0;
		text-align: center;
		color: white;
	}

	.cta-content h2 {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}

	.cta-content p {
		font-size: 1.25rem;
		margin-bottom: 2rem;
		opacity: 0.9;
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cta-section .cta-button.primary {
		background: white;
		color: #667eea;
	}

	.cta-section .cta-button.primary:hover {
		background: #f9fafb;
	}

	.cta-section .cta-button.secondary {
		background: transparent;
		color: white;
		border-color: white;
	}

	.cta-section .cta-button.secondary:hover {
		background: white;
		color: #667eea;
	}

	@media (max-width: 768px) {
		.home-container {
			padding: 0 1rem;
		}

		.hero {
			padding: 3rem 0 2rem;
		}

		.hero-title {
			font-size: 2.5rem;
		}

		.hero-description {
			font-size: 1.125rem;
		}

		.features-grid {
			grid-template-columns: 1fr;
		}

		.posts-grid {
			grid-template-columns: 1fr;
		}

		.section-title {
			font-size: 2rem;
		}

		.cta-content h2 {
			font-size: 2rem;
		}
	}
</style>
